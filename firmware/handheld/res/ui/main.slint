import { StatusBar } from "components/status_bar.slint";
import { TextListView } from "components/list_view.slint";
import { VolumeBar } from "components/volume_bar.slint";
import { RomSelectScreen } from "screens/rom_select.slint";
import { MainMenuScreen } from "screens/main_menu.slint";
import { GameScreen } from "screens/game.slint";
import { SettingsScreen } from "screens/settings/settings.slint";
import { ToolsScreen } from "screens/tools/tools.slint";
import { ErrorScreen } from "screens/error.slint";
import { AboutScreen } from "screens/about.slint";
import { Global, ScreenId, Backend } from "common.slint";
import { PowerMenu } from "components/power_menu.slint";

export { ScreenId, Backend }

export component MainWindow inherits Window {
    private property <string> screen-title;

    protected function update-volume(amount: int) {
        Backend.volume-visible = true;
        Backend.volume-level = clamp(Backend.volume-level + amount, 0, 100);
        Backend.volume-changed(Backend.volume-level);
        Backend.brightness-visible = false;
    }

    protected function update-brightness(amount: int) {
        Backend.brightness-visible = true;
        Backend.brightness-level = clamp(Backend.brightness-level + amount, 0, 100);
        Backend.brightness-changed(Backend.brightness-level);
        Backend.volume-visible = false;
    }

    public function set-screen(screen: ScreenId) {
        Global.set-screen(screen);
    }

    width: 240px;
    height: 160px;
    background: Global.ui-transparent ? transparent : #E8E8E8;
    default-font-family: "pixelmix";
    default-font-size: 8px;

    status-bar := StatusBar {
        visible: Global.ui-status-bar;
        title: root.screen-title;
    }

    focus-scope := FocusScope {
        y: status-bar.height;
        height: parent.height - self.y;

        VerticalLayout {
            padding: 4px;
            Rectangle {
                if (Global.current-screen == ScreenId.MainMenu): MainMenuScreen {
                    init => {
                        self.focus();
                        root.screen-title = self.title;
                    }
                }

                if (Global.current-screen == ScreenId.RomSelect): RomSelectScreen {
                    init => {
                        self.focus();
                        root.screen-title = self.title;
                    }
                }

                if (Global.current-screen == ScreenId.Game): GameScreen {
                    init => {
                        Global.ui-status-bar = false;
                        self.focus();
                        root.screen-title = self.title;
                    }
                }

                if (Global.current-screen == ScreenId.Settings): SettingsScreen {
                    init => {
                        self.focus();
                        root.screen-title = self.title;
                    }
                }

                if (Global.current-screen == ScreenId.Tools): ToolsScreen {
                    init => {
                        self.focus();
                        root.screen-title = self.title;
                    }
                }

                if (Global.current-screen == ScreenId.Error): ErrorScreen {
                    init => {
                        self.focus();
                        root.screen-title = self.title;
                    }
                }

                if (Global.current-screen == ScreenId.About): AboutScreen {
                    init => {
                        self.focus();
                        root.screen-title = self.title;
                    }
                }
            }
        }

        key-pressed(event) => {
            if event.text == "VolUp" || event.text == "q" {
                if Global.home-pressed {
                    Global.home-consumed = true;
                    update-brightness(Backend.brightness-increment);
                } else {
                    update-volume(Backend.volume-increment);
                }
            }
            if event.text == "VolDown" || event.text == "e" {
                if Global.home-pressed {
                    Global.home-consumed = true;
                    update-brightness(-Backend.brightness-increment);
                } else {
                    update-volume(-Backend.volume-increment);
                }
            }
            if (event.text == "Home" || event.text == "h") && !event.repeat {
                Global.home-pressed = true;
                Global.home-consumed = false;
            }
            accept
        }

        key-released(event) => {
            if (event.text == "Home" || event.text == "h") {
                Global.home-pressed = false;
            }
            if (event.text == "Power" || event.text == "p") {
                power-menu.show();
            }
            accept
        }
    }

    if Backend.volume-visible: VolumeBar {
        x: 8px;
        y: parent.height * 0.25;
        height: 50%;
        level: Backend.volume-level;

        icon-0: @image-url("../icons/volume-0.png");
        icon-1: @image-url("../icons/volume-1.png");
        icon-2: @image-url("../icons/volume-2.png");
        icon-3: @image-url("../icons/volume-3.png");
    }

    if Backend.brightness-visible: VolumeBar {
        x: 8px;
        y: parent.height * 0.25;
        height: 50%;
        level: Backend.brightness-level;

        icon-0: @image-url("../icons/brightness-0.png");
        icon-1: @image-url("../icons/brightness-1.png");
        icon-2: @image-url("../icons/brightness-2.png");
        icon-3: @image-url("../icons/brightness-3.png");
    }

    power-menu := PowerMenu {
        // PowerMenu is a PopupWindow and appears conditionally
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
    }
}
